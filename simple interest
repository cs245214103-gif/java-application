<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>
<head>
<title>Simple Interest Calculator</title>

<script>
function calculateSI() {

    let p = parseFloat(document.getElementById("principal").value);
    let r = parseFloat(document.getElementById("rate").value);
    let t = parseFloat(document.getElementById("time").value);

    let si = (p * r * t) / 100;

    document.getElementById("result").innerText = "Simple Interest: " + si;
}
</script>

</head>

<body>

<h2>Simple Interest Calculator</h2>

<label>Principal Amount:</label>
<input type="number" id="principal"><br><br>

<label>Rate of Interest:</label>
<input type="number" id="rate"><br><br>

<label>Time (Years):</label>
<input type="number" id="time"><br><br>

<button onclick="calculateSI()">Calculate</button>

<p id="result"></p>

</body>
</html>
